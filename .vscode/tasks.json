{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "web:dev",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "mobile:web",
      "type": "shell",
      "command": "pnpm web",
      "options": {
        "cwd": "${workspaceFolder}/apps/mobile"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Metro Bundler",
          "endsPattern": "(Metro )?waiting on (http|exp)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "desktop:dev",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/desktop"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "electron-vite",
          "endsPattern": "build the electron main process successfully"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
